# Projects in new but not ref, and vice versa
new_ids = set(n['Project ID'].dropna())
ref_ids = set(r['Project ID'].dropna())
print(f'  Unique Project IDs - NEW: {len(new_ids)}  REF: {len(ref_ids)}')
print(f'  In NEW only: {len(new_ids - ref_ids)}  In REF only: {len(ref_ids - new_ids)}')

# Value differences on shared projects (common cols)
common_cols = [c for c in n.columns if c in r.columns and c != 'Project ID']
merged = n.merge(r, on='Project ID', suffixes=('_new','_ref'))
print(f'  Matched on Project ID: {len(merged):,} rows')
diff_counts = {}
for col in common_cols:
    nc, rc = col+'_new', col+'_ref'
    if nc in merged.columns and rc in merged.columns:
        diffs = (merged[nc].fillna('') != merged[rc].fillna('')).sum()
        if diffs > 0:
            diff_counts[col] = diffs
if diff_counts:
    print('  Column-level differences (mismatched values):')
    for col, cnt in sorted(diff_counts.items(), key=lambda x: -x[1]):
        print(f'    {col}: {cnt:,} rows differ')
else:
    print('  All matched columns are identical on shared projects')
del n, r, merged; gc.collect()
