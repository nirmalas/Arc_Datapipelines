import os, csv, hashlib, json, random
from collections import defaultdict

NEW_DIR = r'C:\Users\seethapn1094\OneDrive - ARCADIS\Documents\DataScience\NYPA\P6\NYPA_ADF\AzureP6Pipeline_V2\local_outputs'
REF_DIR = r'C:\Users\seethapn1094\OneDrive - ARCADIS\Documents\DataScience\NYPA\P6\ProdLoad_updated\output_20May'

pairs = {
  'project': (os.path.join(NEW_DIR,'project','PJC_business_P6_FullProjectList.csv'),
              os.path.join(REF_DIR,'PJC_business_P6_FullProjectList_15May.csv'), 'Project ID'),
  'activity':(os.path.join(NEW_DIR,'activity','PJC_business_P6_FullActivityList.csv'),
              os.path.join(REF_DIR,'PJC_business_P6_FullActivityList_15May.csv'), 'Activity ID'),
  'spread':  (os.path.join(NEW_DIR,'spread','PJC_report_p6_spread.csv'),
              os.path.join(REF_DIR,'PJC_report_p6_spread_20260515_110000.csv'), None),
  'finance': (os.path.join(NEW_DIR,'finance','P6_to_SAC-P_Finance.csv'),
              os.path.join(REF_DIR,'P6_to_SAC-P_Finance_Output.csv'), None),
  'finance_filtered': (os.path.join(NEW_DIR,'finance','P6_to_SAC-P_Finance_Filtered.csv'),
              os.path.join(REF_DIR,'P6_to_SAC-P_Finance_Filtered_Output.csv'), None),
}

summary = {}

for label,(newp, refp, idcol) in pairs.items():
    print(f'Processing {label}...')
    s = {}
    s['new_path']=newp
    s['ref_path']=refp
    try:
        s['new_size']=os.path.getsize(newp)
    except Exception as e:
        s['new_size']=None
        s['error_new']=str(e)
    try:
        s['ref_size']=os.path.getsize(refp)
    except Exception as e:
        s['ref_size']=None
        s['error_ref']=str(e)

    # headers
    try:
        with open(newp, 'r', encoding='utf-8', errors='replace') as f:
            reader=csv.reader(f)
            new_hdr=next(reader)
    except Exception as e:
        new_hdr=[]
        s['error_new_hdr']=str(e)
    try:
        with open(refp, 'r', encoding='utf-8', errors='replace') as f:
            reader=csv.reader(f)
            ref_hdr=next(reader)
    except Exception as e:
        ref_hdr=[]
        s['error_ref_hdr']=str(e)
    s['new_columns']=new_hdr
    s['ref_columns']=ref_hdr
    s['columns_new_only']=list(set(new_hdr)-set(ref_hdr))
    s['columns_ref_only']=list(set(ref_hdr)-set(new_hdr))

    # row counts and id sets if applicable; also md5 for whole file
    def file_rowcount_and_ids(path, idcolname=None, sample_ids=set()):
        rows=0
        ids=set()
        md5=hashlib.md5()
        # for sample extraction, store mapping id->row for sample ids requested
        sample_rows={}
        try:
            with open(path,'rb') as bf:
                for chunk in iter(lambda: bf.read(8192), b''):
                    md5.update(chunk)
        except Exception:
            md5=None
        try:
            with open(path,'r', encoding='utf-8', errors='replace') as f:
                reader=csv.DictReader(f)
                for row in reader:
                    rows+=1
                    if idcolname and idcolname in row:
                        ids.add(row[idcolname])
                        if row[idcolname] in sample_ids:
                            sample_rows[row[idcolname]]=row
        except Exception:
            pass
        return rows, ids, md5.hexdigest() if md5 else None, sample_rows

    # pick sample ids later from intersection
    if idcol:
        new_rows,new_ids, new_md5, _ = file_rowcount_and_ids(newp, idcol, set())
        ref_rows,ref_ids, ref_md5, _ = file_rowcount_and_ids(refp, idcol, set())
        s['new_rows']=new_rows
        s['ref_rows']=ref_rows
        s['new_md5']=new_md5
        s['ref_md5']=ref_md5
        s['new_unique_ids']=len(new_ids)
        s['ref_unique_ids']=len(ref_ids)
        only_new = new_ids - ref_ids
        only_ref = ref_ids - new_ids
        s['ids_in_new_only']=len(only_new)
        s['ids_in_ref_only']=len(only_ref)
        # sample up to 20 intersection ids
        inter = list(new_ids & ref_ids)
        random.seed(0)
        sample = set(random.sample(inter, min(20, len(inter)))) if inter else set()
        # re-scan and capture sample rows
        _,_,_, new_sample_rows = file_rowcount_and_ids(newp, idcol, sample)
        _,_,_, ref_sample_rows = file_rowcount_and_ids(refp, idcol, sample)
        diffsamples=[]
        for sid in sample:
            nr=new_sample_rows.get(sid)
            rr=ref_sample_rows.get(sid)
            if not nr or not rr:
                diffsamples.append({'id':sid,'status':'missing in one side'})
                continue
            # compare values per column intersection
            cols = set(nr.keys()) ;& set(rr.keys())
            col_diffs={}
            for c in cols:
                if (nr.get(c) or '') != (rr.get(c) or ''):
                    col_diffs[c]={'new':nr.get(c),'ref':rr.get(c)}
            if col_diffs:
                diffsamples.append({'id':sid,'differences':col_diffs})
        s['sample_diffs']=diffsamples
    else:
        # no id column: compute rowcount and md5
        new_rows,_, new_md5,_ = file_rowcount_and_ids(newp,None,set())
        ref_rows,_, ref_md5,_ = file_rowcount_and_ids(refp,None,set())
        s['new_rows']=new_rows
        s['ref_rows']=ref_rows
        s['new_md5']=new_md5
        s['ref_md5']=ref_md5

    summary[label]=s

outpath=os.path.join(NEW_DIR,'compare_summary.json')
with open(outpath,'w',encoding='utf-8') as f:
    json.dump(summary,f,indent=2)
print('\nComparison complete. Summary written to:', outpath)
